# =============================================================================
# HeatherBot Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Telegram credentials (from https://my.telegram.org)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Admin Telegram user ID (your personal account numeric ID)
ADMIN_USER_ID=0

# Payment bot token (from @BotFather — optional, for Telegram Stars tipping)
PAYMENT_BOT_TOKEN=
# Payment bot @username (no @ prefix) — used in tip messages
PAYMENT_BOT_USERNAME=YourPaymentBot

# Monitoring dashboard auth key (leave empty for open access on localhost)
MONITOR_AUTH_TOKEN=change_me_to_something_secret

# ComfyUI face-swap source image path (for image generation)
COMFYUI_FACE_IMAGE=C:/ComfyUI/input/face_source.png
